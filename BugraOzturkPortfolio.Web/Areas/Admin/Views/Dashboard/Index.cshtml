@{
    ViewData["Title"] = "Dashboard";
}

<div class="pagetitle">
    <h1>Dashboard</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Dashboard">Home</a></li>
            <li class="breadcrumb-item active">Dashboard</li>
        </ol>
    </nav>
</div>

<section class="section dashboard">
    <div class="row g-3 mb-4">
        <div class="col-xxl-3 col-md-6">
            <div class="card info-card sales-card">
                <div class="card-body">
                    <h5 class="card-title">Ziyaretçi Periyotları <span>| Hit</span></h5>
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-primary-subtle text-primary" style="width: 50px; height: 50px;">
                            <i class="bi bi-eye fs-4"></i>
                        </div>
                        <div class="ps-3">
                            <span class="d-block small">Bugün: <strong class="">@ViewBag.DailyVisitors</strong></span>
                            <span class="d-block small">Bu Hafta: <strong class="">@ViewBag.WeeklyVisitors</strong></span>
                            <span class="d-block small">Bu Ay: <strong class="">@ViewBag.MonthlyVisitors</strong></span>
                            <span class="d-block small">Bu Yıl: <strong class="">@ViewBag.YearlyVisitors</strong></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xxl-3 col-md-6">
            <div class="card info-card revenue-card">
                <div class="card-body">
                    <h5 class="card-title">Gelen Mesajlar <span>| Okunmadı</span></h5>
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-warning-subtle text-warning" style="width: 50px; height: 50px;">
                            <i class="bi bi-envelope-open fs-4"></i>
                        </div>
                        <div class="ps-3">
                            <h6 class="fs-4 mb-0 fw-bold text-warning">@ViewBag.UnreadMessagesCount</h6>
                            <span class="text-muted small">Okunmayı bekleyen Mesajlar</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xxl-3 col-md-6">
            <div class="card info-card revenue-card">
                <div class="card-body">
                    <h5 class="card-title">Toplam İletişim <span>| Arşiv</span></h5>
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-info-subtle text-info" style="width: 50px; height: 50px;">
                            <i class="bi bi-chat-square-text fs-4"></i>
                        </div>
                        <div class="ps-3">
                            <h6 class="fs-4 mb-0 fw-bold text-info">@ViewBag.TotalMessagesCount</h6>
                            <span class="text-muted small">Gelen toplam mesajlar</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xxl-3 col-md-6">
            <div class="card info-card customers-card">
                <div class="card-body">
                    <h5 class="card-title">Portfolyo Vitrini <span>| Proje</span></h5>
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-success-subtle text-success" style="width: 50px; height: 50px;">
                            <i class="bi bi-code-slash fs-4"></i>
                        </div>
                        <div class="ps-3">
                            <h6 class="fs-4 mb-0 fw-bold text-success">@ViewBag.TotalProjectsCount</h6>
                            <span class="text-muted small">Aktif sergilenen portfolyolar</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Son 1 Haftalık Organik Ziyaretçi Trendi</h5>
                </div>
                <div class="card-body pt-3">
                    <div id="visitorLineTrendChart" style="min-height: 290px;"></div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="card-title"><i class="bi bi-pie-chart-fill me-2 text-warning"></i>En Yoğun Ziyaret Alan 5 Gün</h5>
                </div>
                <div class="card-body pt-3">
                    <canvas id="topDaysPieChart" style="max-height: 290px; width: 100%;"></canvas>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {

            const accentColor = getComputedStyle(document.documentElement).getPropertyValue('--accent-color').trim() || '#3b82f6';
            const warningColor = getComputedStyle(document.documentElement).getPropertyValue('--warning-color').trim() || '#f59e0b';
            const successColor = getComputedStyle(document.documentElement).getPropertyValue('--success-color').trim() || '#22c55e';
            const infoColor = getComputedStyle(document.documentElement).getPropertyValue('--info-color').trim() || '#06b6d4';
            const dangerColor = getComputedStyle(document.documentElement).getPropertyValue('--danger-color').trim() || '#ef6868';


            var lineOptions = {
                chart: {
                    type: 'area',
                    height: 290,
                    fontFamily: 'inherit',
                    toolbar: { show: false },
                    zoom: { enabled: false }
                },
                series: [{
                    name: 'Tekil Ziyaretçi',
                    data: [@Html.Raw(ViewBag.WeekHistoryValues)]
                }],
                colors: [accentColor],
                stroke: { width: 3, curve: 'smooth' },
                fill: {
                    type: 'gradient',
                    gradient: {
                        shadeIntensity: 1,
                        opacityFrom: 0.45,
                        opacityTo: 0.05,
                        stops: [50, 100]
                    }
                },
                xaxis: {
                    categories: [@Html.Raw(ViewBag.WeekHistoryLabels)],
                    labels: { style: { fontSize: '11px' } }
                },
                dataLabels: { enabled: false },
                markers: { size: 4, strokeWidth: 0, hover: { size: 6 } },
                grid: { strokeDashArray: 4 }
            };

            var trendChart = new ApexCharts(document.querySelector('#visitorLineTrendChart'), lineOptions);
            trendChart.render();

            new Chart(document.getElementById('topDaysPieChart'), {
                type: 'pie',
                data: {
                    labels: [@Html.Raw(ViewBag.TopDaysLabels)],
                    datasets: [{
                        data: [@Html.Raw(ViewBag.TopDaysValues)],
                        backgroundColor: [accentColor, successColor, warningColor, infoColor, dangerColor],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { usePointStyle: true, padding: 12 }
                        }
                    }
                }
            });
        });
    </script>
}