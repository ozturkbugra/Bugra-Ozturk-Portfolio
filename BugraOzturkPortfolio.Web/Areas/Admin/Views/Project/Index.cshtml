@{
    ViewData["Title"] = "Proje Yönetimi";
}

<div class="container-fluid">
    <div class="page-header fx-page-header">
        <div>
            <h1 class="page-title">Projelerim</h1>
            <p class="fx-subtitle">Portfolyonuzda sergilenecek projelerin yönetim, listelememd ve düzenleme paneli.</p>
        </div>
        <div class="page-header-actions">
            <button class="btn btn-primary btn-sm" onclick="openCreateModal()">
                <i class="bi bi-plus-lg me-1"></i> Yeni Proje Ekle
            </button>
        </div>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        <div id="projectToast" class="toast align-items-center text-white border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center">
                    <i id="toastIcon" class="bi me-2 fs-5"></i>
                    <span id="toastMessage"></span>
                </div>
                <button type="button" class="btn-close btn-close-white m-auto me-2" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <div class="row">

        <div class="row d-none" id="projectDetailPanel">
            <div class="col-12 mb-3">
                <button class="btn btn-outline-secondary btn-sm" onclick="closeProjectDetailPanel()">
                    <i class="bi bi-arrow-left me-1"></i> Projelere Geri Dön
                </button>
                <span class="fs-4 fw-bold ms-3 text-primary" id="detailPanelProjectTitle">Proje Detayları</span>
            </div>

            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">Slider Görselleri</h5>
                        <div>
                            <input type="file" id="detailGalleryInput" accept="image/*" class="d-none" onchange="uploadSingleGalleryImage()" />
                            <button class="btn btn-success btn-sm" onclick="document.getElementById('detailGalleryInput').click()">
                                <i class="bi bi-cloud-upload me-1"></i> Yeni Görsel Ekle
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div id="detailGalleryWrapper" class="row g-3">
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Proje Teknik Özellikleri</h5>
                    </div>
                    <div class="card-body">
                        <form id="featureForm" class="row g-2 mb-4 align-items-end" novalidate>
                            <input type="hidden" id="FeatureId" name="Id" />
                            <input type="hidden" id="FeatureProjectId" name="ProjectId" />

                            <div class="col-md-4">
                                <label class="form-label small fw-semibold">Özellik Başlığı</label>
                                <input type="text" class="form-control form-control-sm" id="FeatureTitle" name="Title" placeholder="Örn: Yüksek Performans" required />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label small fw-semibold">Kısa Açıklama</label>
                                <input type="text" class="form-control form-control-sm" id="FeatureDescription" name="Description" placeholder="Örn: %100 asenkron altyapı..." required />
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-primary btn-sm w-100" id="btnFeatureSubmit">Ekle</button>
                            </div>
                        </form>

                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Başlık</th>
                                        <th>Açıklama</th>
                                        <th class="text-end">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody id="featureTableBody">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">Mevcut Projeler</h5>
                </div>
                <div class="card-body">
                    <table class="table align-middle" id="projectTable">
                        <thead>
                            <tr>
                                <th>Görsel</th>
                                <th>Proje Başlığı</th>
                                <th>Müşteri / İstemci</th>
                                <th>Proje Tarihi</th>
                                <th>Sıra</th>
                                <th class="text-end">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody id="projectTableBody">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="projectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Yeni Proje Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="projectForm" enctype="multipart/form-data" novalidate>
                    <input type="hidden" id="Id" name="Id" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label for="Title" class="form-label fw-semibold">Proje Başlığı</label>
                            <input type="text" class="form-control" id="Title" name="Title" required placeholder="Örn: Mini ERP Projesi">
                        </div>
                        <div class="col-md-4">
                            <label for="Order" class="form-label fw-semibold">Görüntüleme Sırası</label>
                            <input type="number" class="form-control" id="Order" name="Order" value="0" required>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="Client" class="form-label fw-semibold">Müşteri / İstemci</label>
                            <input type="text" class="form-control" id="Client" name="Client" placeholder="Örn: Metaş Yazılım veya Freelance">
                        </div>
                        <div class="col-md-6">
                            <label for="ProjectDate" class="form-label fw-semibold">Proje Tarihi</label>
                            <input type="date" class="form-control" id="ProjectDate" name="ProjectDate">
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="ProjectUrl" class="form-label fw-semibold">Canlı Önizleme Linki (Opsiyonel)</label>
                            <input type="url" class="form-control" id="ProjectUrl" name="ProjectUrl" placeholder="https://...">
                        </div>
                        <div class="col-md-6">
                            <label for="GithubUrl" class="form-label fw-semibold">GitHub Repo Linki (Opsiyonel)</label>
                            <input type="url" class="form-control" id="GithubUrl" name="GithubUrl" placeholder="https://github.com/...">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="ShortDescription" class="form-label fw-semibold">Kısa Açıklama (Listeleme Alanı İçin)</label>
                        <input type="text" class="form-control" id="ShortDescription" name="ShortDescription" required placeholder="Projenin kart üzerinde görünecek tek cümlelik özeti.">
                    </div>

                    <div class="mb-3">
                        <label for="ProjectCategories" class="form-label fw-semibold">Proje Kategorileri</label>
                        <select class="form-select" id="ProjectCategories" name="SelectedCategoryIds" multiple data-choices data-choices-removeitem="true" data-choices-search="true">
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Detaylı Proje Açıklaması</label>
                        <div id="projectQuill" style="height: 180px;"></div>
                        <input type="hidden" id="FullDescription" name="FullDescription" />
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Proje Kapak Görseli</label>
                            <div class="upload-dropzone p-3 border border-2 border-dashed rounded text-center bg-light" id="projectDropzone" style="cursor: pointer; border-color: var(--accent-color) !important;">
                                <i class="bi bi-images fs-2 text-primary"></i>
                                <h6 class="mt-2">Görsel sürükleyin veya tıklayın</h6>
                                <input type="file" id="CoverImageFile" name="CoverImageFile" accept="image/*" class="d-none" />
                            </div>
                            <div class="mt-3 text-center d-none" id="projectPreviewContainer">
                                <img id="projectImgPreview" src="#" class="img-thumbnail" style="max-height: 120px; object-fit: cover;" alt="Önizleme" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Proje Ek Galeri Resimleri (Çoklu)</label>
                            <input type="file" id="ProjectImagesFiles" name="ProjectImagesFiles" accept="image/*" class="form-control" multiple />
                            <small class="text-muted">Proje detay sayfasında slider olarak görünecek ek resimler.</small>
                        </div>
                    </div>

                    <div class="text-end border-top pt-3">
                        <button type="button" class="btn btn-outline-secondary me-2" data-bs-dismiss="modal">Vazgeç</button>
                        <button type="submit" id="btnProjectSubmit" class="btn btn-primary px-4">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let dataTable;
        let quill;
        let choicesInstance;
        const modalEl = document.getElementById('projectModal');
        const bootstrapModal = new bootstrap.Modal(modalEl);

        document.addEventListener('DOMContentLoaded', function () {
            quill = new Quill('#projectQuill', {
                theme: 'snow',
                placeholder: 'Proje detaylarını, kullanılan teknolojileri yazın...',
                modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['clean']] }
            });

            initProjectCategorySelect().then(() => {
                loadProjects();
            });

            const dropzone = document.getElementById('projectDropzone');
            const fileInput = document.getElementById('CoverImageFile');
            const previewContainer = document.getElementById('projectPreviewContainer');
            const imgPreview = document.getElementById('projectImgPreview');

            dropzone.addEventListener('click', () => fileInput.click());
            fileInput.addEventListener('change', function () { handleProjectFile(this.files[0]); });

            dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('bg-secondary-subtle'); });
            dropzone.addEventListener('dragleave', () => dropzone.classList.remove('bg-secondary-subtle'));
            dropzone.addEventListener('drop', function (e) {
                e.preventDefault();
                dropzone.classList.remove('bg-secondary-subtle');
                const file = e.dataTransfer.files[0];
                if (file && file.type.startsWith('image/')) {
                    fileInput.files = e.dataTransfer.files;
                    handleProjectFile(file);
                }
            });

            function handleProjectFile(file) {
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        imgPreview.src = e.target.result;
                        previewContainer.classList.remove('d-none');
                    }
                    reader.readAsDataURL(file);
                }
            }

            const form = document.getElementById('projectForm');
            form.addEventListener('submit', function (e) {
                e.preventDefault();

                if (!document.getElementById('Title').value.trim() || !document.getElementById('ShortDescription').value.trim()) {
                    showProjectToast('Lütfen gerekli alanları doldurunuz!', false);
                    return;
                }

                const quillHtml = quill.root.innerHTML;
                if (quillHtml === '<p><br></p>' || quillHtml.trim() === '') {
                    showProjectToast('Lütfen proje detaylı açıklamasını yazınız!', false);
                    return;
                }
                document.getElementById('FullDescription').value = quillHtml;

                const formData = new FormData(form);
                const btnSubmit = document.getElementById('btnProjectSubmit');
                btnSubmit.disabled = true;
                btnSubmit.textContent = 'Kaydediliyor...';

                fetch('/Admin/Project/Save', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showProjectToast(data.message, true);
                        bootstrapModal.hide();
                        loadProjects();
                    } else {
                        showProjectToast(data.message, false);
                    }
                })
                .catch(() => showProjectToast('Sistem hatası oluştu!', false))
                .finally(() => {
                    btnSubmit.disabled = false;
                    btnSubmit.textContent = 'Kaydet';
                });
            });
        });

        function loadProjects() {
            fetch('/Admin/Project/GetProjectsJson')
                .then(response => response.json())
                .then(data => {
                    if (dataTable) {
                        dataTable.destroy();
                    }

                    const tbody = document.getElementById('projectTableBody');
                    tbody.innerHTML = '';

                    data.forEach(item => {
                        const dateStr = item.projectDate ? new Date(item.projectDate).toLocaleDateString('tr-TR') : '-';
                        const imgUrl = item.coverImageUrl ? item.coverImageUrl : '/Admin/assets/img/logo.webp';

                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td><img src="${imgUrl}" class="rounded" style="width:50px; height:35px; object-fit:cover;" /></td>
                            <td class="fw-semibold">${item.title}</td>
                            <td>${item.client ?? '-'}</td>
                            <td>${dateStr}</td>
                            <td><span class="badge bg-secondary">${item.order}</span></td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm me-1" href="/Admin/Project/Detail/${item.id}" title="Detayları Yönet">
                                    <i class="bi bi-gear"></i> Detayları Yönet
                                </a>
                                <button class="btn btn-outline-warning btn-sm me-1" onclick="openEditModal('${item.id}')" title="Düzenle"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteProject('${item.id}')" title="Sil"><i class="bi bi-trash"></i></button>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });

                    dataTable = new simpleDatatables.DataTable("#projectTable", {
                        searchable: true,
                        perPage: 10,
                        labels: { placeholder: "Ara...", perPage: "{select} satır göster", noRows: "Kayıt bulunamadı", info: "{rows} kayıttan {start} ile {end} arası gösteriliyor" }
                    });
                });
        }

        function openCreateModal() {
            document.getElementById('projectForm').reset();
            document.getElementById('Id').value = "00000000-0000-0000-0000-000000000000";
            if (choicesInstance) {
                choicesInstance.removeActiveItems();
            }
            quill.root.innerHTML = '';
            document.getElementById('projectPreviewContainer').classList.add('d-none');
            document.getElementById('modalTitle').textContent = 'Yeni Proje Ekle';
            bootstrapModal.show();
        }

        function openEditModal(id) {
            fetch(`/Admin/Project/GetProjectById?id=${id}`)
                .then(response => response.json())
                .then(res => {
                    if (res.success) {
                        const item = res.data;
                        document.getElementById('Id').value = item.id;
                        document.getElementById('Title').value = item.title;
                        document.getElementById('Order').value = item.order;
                        document.getElementById('Client').value = item.client;
                        document.getElementById('ShortDescription').value = item.shortDescription;
                        document.getElementById('ProjectUrl').value = item.projectUrl;
                        document.getElementById('GithubUrl').value = item.githubUrl;

                        if (item.projectDate) {
                            document.getElementById('ProjectDate').value = item.projectDate.split('T')[0];
                        } else {
                            document.getElementById('ProjectDate').value = '';
                        }

                        if (choicesInstance && item.categoryMappings) {
                            choicesInstance.removeActiveItems();
                            const mappedIds = item.categoryMappings.map(m => m.categoryId);
                            choicesInstance.setChoiceByValue(mappedIds);
                        }

                        quill.root.innerHTML = item.fullDescription ?? '';

                        const previewContainer = document.getElementById('projectPreviewContainer');
                        const imgPreview = document.getElementById('projectImgPreview');
                        if (item.coverImageUrl) {
                            imgPreview.src = item.coverImageUrl;
                            previewContainer.classList.remove('d-none');
                        } else {
                            previewContainer.classList.add('d-none');
                        }

                        document.getElementById('modalTitle').textContent = 'Proje Düzenle';
                        bootstrapModal.show();
                    } else {
                        showProjectToast(res.message, false);
                    }
                });
        }

        function deleteProject(id) {
            if (confirm('Bu projeyi silmek istediğinize emin misiniz aga?')) {
                fetch(`/Admin/Project/Delete?id=${id}`, { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showProjectToast(data.message, true);
                            loadProjects();
                        } else {
                            showProjectToast(data.message, false);
                        }
                    });
            }
        }

        function showProjectToast(message, isSuccess) {
            const toastEl = document.getElementById('projectToast');
            document.getElementById('toastMessage').textContent = message;
            if (isSuccess) {
                toastEl.className = 'toast align-items-center text-white border-0 bg-success';
                document.getElementById('toastIcon').className = 'bi bi-check2-circle me-2 fs-5';
            } else {
                toastEl.className = 'toast align-items-center text-white border-0 bg-danger';
                document.getElementById('toastIcon').className = 'bi bi-exclamation-triangle me-2 fs-5';
            }
            new bootstrap.Toast(toastEl).show();
        }

        function initProjectCategorySelect() {
            return fetch('/Admin/Category/GetCategoriesJson')
                .then(response => response.json())
                .then(data => {
                    const select = document.getElementById('ProjectCategories');
                    select.innerHTML = '';
                    data.forEach(cat => {
                        const option = document.createElement('option');
                        option.value = cat.id;
                        option.textContent = cat.name;
                        select.appendChild(option);
                    });

                    choicesInstance = new Choices(select, {
                        removeItemButton: true,
                        searchEnabled: true,
                        itemSelectText: '',
                        searchPlaceholderValue: 'Kategori ara...'
                    });
                });
        }


                let currentActiveProjectId = null;

        // 1. PANELİ AÇMA VE VERİLERİ HAVADA DETAYLANDIRMA
        function openProjectDetailPanel(projectId, projectTitle) {
            currentActiveProjectId = projectId;
            document.getElementById('detailPanelProjectTitle').textContent = projectTitle + " - Detay Yönetimi";
            document.getElementById('FeatureProjectId').value = projectId;

            // Ana listeyi gizle, detay panelini patlat aga
            document.getElementById('projectTable').closest('.row').classList.add('d-none');
            document.getElementById('projectDetailPanel').classList.remove('d-none');

            // Verileri asenkron yükle
            loadDetailGallery();
            loadDetailFeatures();
        }

        function closeProjectDetailPanel() {
            currentActiveProjectId = null;
            document.getElementById('projectDetailPanel').classList.add('d-none');
            document.getElementById('projectTable').closest('.row').classList.remove('d-none');
        }

        // 2. TEKİL GALERİ RESİMLERİNİ GETİRME VE SİLME ŞOVU
        function loadDetailGallery() {
            fetch(`/Admin/Project/GetProjectById?id=${currentActiveProjectId}`)
                .then(response => response.json())
                .then(res => {
                    const wrapper = document.getElementById('detailGalleryWrapper');
                    wrapper.innerHTML = '';

                    if (!res.success || !res.data.projectImages || res.data.projectImages.length === 0) {
                        wrapper.innerHTML = '<div class="col-12 text-center text-muted py-4">Bu projeye ait henüz bir galeri resmi yok aga.</div>';
                        return;
                    }

                    res.data.projectImages.forEach(img => {
                        const div = document.createElement('div');
                        div.className = 'col-md-4 col-6 position-relative gallery-item-box';
                        div.innerHTML = `
                            <div class="card p-1 border">
                                <img src="${img.imageUrl}" class="rounded w-100" style="height: 100px; object-fit: cover;" />
                                <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-2 p-0 d-flex align-items-center justify-content-center rounded-circle"
                                        style="width: 24px; height: 24px;" onclick="deleteDetailGalleryImage('${img.id}')" title="Görseli Sil">
                                    <i class="bi bi-trash fs-6"></i>
                                </button>
                            </div>
                        `;
                        wrapper.appendChild(div);
                    });
                });
        }

        function uploadSingleGalleryImage() {
            const fileInput = document.getElementById('detailGalleryInput');
            if (fileInput.files.length === 0) return;

            const formData = new FormData();
            formData.append('projectId', currentActiveProjectId);
            formData.append('galleryFile', fileInput.files[0]);

            fetch('/Admin/Project/AddGalleryImage', { method: 'POST', body: formData })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showProjectToast(data.message, true);
                        loadDetailGallery(); // Havada tazeleyin aga
                    } else {
                        showProjectToast(data.message, false);
                    }
                    fileInput.value = ''; // Inputu temizle
                });
        }

        function deleteDetailGalleryImage(imageId) {
            if (confirm('Bu görseli sunucudan ve galeriden kalıcı olarak silmek istediğine emin misiniz aga?')) {
                const formData = new FormData();
                formData.append('imageId', imageId);

                fetch('/Admin/Project/DeleteGalleryImage', { method: 'POST', body: formData })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showProjectToast(data.message, true);
                            loadDetailGallery();
                        } else {
                            showProjectToast(data.message, false);
                        }
                    });
            }
        }

        // 3. DİNAMİK ÖZELLİK (FEATURE) AJAL TRAFİĞİ
        function loadDetailFeatures() {
            fetch(`/Admin/Project/GetFeatures?projectId=${currentActiveProjectId}`)
                .then(response => response.json())
                .then(data => {
                    const tbody = document.getElementById('featureTableBody');
                    tbody.innerHTML = '';

                    if (data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-3">Bu projeye ait teknik özellik eklenmemiş.</td></tr>';
                        return;
                    }

                    data.forEach(item => {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td class="fw-semibold text-dark">${item.title}</td>
                            <td class="text-muted small">${item.description}</td>
                            <td class="text-end">
                                <button class="btn btn-link text-danger btn-sm p-0" onclick="deleteDetailFeature('${item.id}')"><i class="bi bi-trash"></i></button>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                });
        }

        // Özellik Formu Gönderimi (Ekleme)
        document.getElementById('featureForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const title = document.getElementById('FeatureTitle').value.trim();
            const desc = document.getElementById('FeatureDescription').value.trim();
            if (!title || !desc) return;

            const formData = new FormData(this);

            fetch('/Admin/Project/SaveFeature', { method: 'POST', body: formData })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showProjectToast(data.message, true);
                        document.getElementById('featureForm').reset();
                        document.getElementById('FeatureId').value = '';
                        document.getElementById('FeatureProjectId').value = currentActiveProjectId;
                        loadDetailFeatures(); // Listeyi anlık tazele aga
                    } else {
                        showProjectToast(data.message, false);
                    }
                });
        });

        function deleteDetailFeature(featureId) {
            if (confirm('Bu teknik özelliği silmek istediğinize emin misiniz aga?')) {
                const formData = new FormData();
                formData.append('featureId', featureId);

                fetch('/Admin/Project/DeleteFeature', { method: 'POST', body: formData })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showProjectToast(data.message, true);
                            loadDetailFeatures();
                        } else {
                            showProjectToast(data.message, false);
                        }
                    });
            }
        }
    </script>
}