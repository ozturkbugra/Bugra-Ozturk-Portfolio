@model List<MailDisplayViewModel>
@{
    ViewData["Title"] = "E-Posta";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    string currentFolder = ViewBag.CurrentFolder ?? "INBOX";
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger border-0 shadow-sm mb-3">
        <i class="bi bi-exclamation-triangle me-2"></i> @ViewBag.Error
    </div>
}

<div class="email-container">
    <div class="email-sidebar-overlay" id="emailSidebarOverlay"></div>

    <div class="email-sidebar" id="emailSidebar">
        <button class="email-sidebar-close" id="emailSidebarClose" aria-label="Menüyü kapat">
            <i class="bi bi-x-lg"></i>
        </button>
        <div class="email-sidebar-header">
            <button class="btn btn-primary w-100" data-bs-toggle="modal" data-bs-target="#composeModal">
                <i class="bi bi-pencil-square me-2"></i>E-Posta Yaz
            </button>
        </div>

        <nav class="email-nav">
            <ul class="email-nav-list">
                <li class="email-nav-item @(currentFolder.Equals("INBOX", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="window.location.href='/Admin/Email?folder=INBOX'">
                    <i class="bi bi-inbox"></i>
                    <span>Gelen Kutusu</span>
                    @if (currentFolder.Equals("INBOX", StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="email-nav-badge">@Model.Count</span>
                    }
                </li>
                <li class="email-nav-item @(currentFolder.Equals("Sent", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="window.location.href='/Admin/Email?folder=Sent'">
                    <i class="bi bi-send"></i>
                    <span>Gönderilenler</span>
                    @if (currentFolder.Equals("Sent", StringComparison.OrdinalIgnoreCase))
                    {
                        <span class="email-nav-badge">@Model.Count</span>
                    }
                </li>
                <li class="email-nav-item @(currentFolder.Equals("Trash", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="window.location.href='/Admin/Email?folder=Trash'">
                    <i class="bi bi-trash"></i>
                    <span>Çöp Kutusu</span>
                </li>
            </ul>
        </nav>
    </div>

    <div class="email-main" id="emailMain">
        <div class="email-list-view" id="emailListView">
            <div class="email-list-header">
                <button class="email-sidebar-toggle" id="emailSidebarToggle" aria-label="Klasörleri aç">
                    <i class="bi bi-folder"></i>
                </button>

                <div class="email-list-actions">
                    <button class="email-action-btn" title="Yenile" onclick="window.location.reload();">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
                <div class="email-search">
                    <i class="bi bi-search email-search-icon"></i>
                    <input type="text" id="emailSearchInput" class="form-control" placeholder="E-postalar içinde ara...">
                </div>
            </div>

            <div class="email-list">
                @if (Model != null && Model.Any())
                {
                    foreach (var mail in Model)
                    {
                        <div class="email-item unread"
                             data-sender-name="@mail.FromName"
                             data-sender-mail="@mail.FromAddress"
                             data-subject="@mail.Subject"
                             data-date="@mail.Date.ToString("dd MMM yyyy, HH:mm", new System.Globalization.CultureInfo("tr-TR"))">

                            <div class="email-item-avatar bg-primary-light text-primary d-flex align-items-center justify-content-center fw-bold" style="width:36px; height:36px; border-radius:50%;">
                                <span>@mail.FromName.Replace("Kime: ", "").AsSpan(0, Math.Min(2, mail.FromName.Replace("Kime: ", "").Length)).ToString().ToUpper()</span>
                            </div>
                            <div class="email-item-content">
                                <div class="email-item-header">
                                    <span class="email-item-sender">@mail.FromName</span>
                                    <span class="email-item-time">@mail.Date.ToString("HH:mm")</span>
                                </div>
                                <div class="email-item-subject">@mail.Subject</div>
                                <div class="email-item-preview">@mail.Snippet</div>
                            </div>
                            <div class="d-none-mail-body d-none">@Html.Raw(mail.Body)</div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 text-muted small">Bu klasörde e-posta bulunmuyor aga.</div>
                }
            </div>
        </div>

        <div class="email-detail-view" id="emailDetailView" style="display: none;">
            <div class="email-detail-header">
                <button class="email-back-btn" id="emailBackBtn" title="Listeye Geri Dön">
                    <i class="bi bi-arrow-left"></i>
                </button>
                <div class="email-detail-actions">
                    <button class="email-action-btn" title="Cevapla" onclick="replyCurrentEmail()">
                        <i class="bi bi-reply"></i>
                    </button>
                </div>
            </div>

            <div class="email-detail-content w-100">
                <div class="email-detail-subject">
                    <h4 id="viewSubject">Konu Başlığı</h4>
                </div>

                <div class="email-message">
                    <div class="email-message-header">
                        <div class="email-message-sender">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-2" style="width: 40px; height: 40px;" id="viewAvatar">B</div>
                            <div class="email-message-sender-info">
                                <div class="email-message-sender-name">
                                    <span id="viewSenderName">Gönderen Adı</span>
                                    <span class="email-message-sender-email" id="viewSenderMail">&lt;sender@example.com&gt;</span>
                                </div>
                            </div>
                        </div>
                        <div class="email-message-meta">
                            <span class="email-message-date" id="viewDate">Tarih Bilgisi</span>
                        </div>
                    </div>

                    <div class="email-message-body text-body p-3" id="viewBody" style="min-height:200px; overflow-y:auto; line-height: 1.6;">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="composeModal" tabindex="-1" aria-labelledby="composeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="composeModalLabel">Yeni Mesaj</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body">
                <form id="composeForm" novalidate>
                    <div class="mb-3">
                        <label class="form-label">Alıcı (To)</label>
                        <input type="email" class="form-control" id="composeTo" name="to" placeholder="Alıcı e-posta adresi..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Konu</label>
                        <input type="text" class="form-control" id="composeSubject" name="subject" placeholder="Mesaj konusu..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mesaj İçeriği</label>
                        <div id="emailQuillEditor" style="height: 220px;"></div>
                        <input type="hidden" id="composeBody" name="body" />
                    </div>
                </form>
            </div>
            <div class="modal-footer justify-content-end gap-2">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Vazgeç</button>
                <button type="button" id="btnSendEmail" class="btn btn-primary" onclick="submitComposeForm()">
                    <i class="bi bi-send me-1"></i>Gönder
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let emailQuill;
        const composeModalInstance = new bootstrap.Modal(document.getElementById('composeModal'));

        document.addEventListener('DOMContentLoaded', function() {
            // Quill Editör Kurulumu
            emailQuill = new Quill('#emailQuillEditor', {
                theme: 'snow',
                placeholder: 'Mesajınızı buraya yazın aga...',
                modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['clean']] }
            });

            const emailItems = document.querySelectorAll('.email-item');
            const emailListView = document.getElementById('emailListView');
            const emailDetailView = document.getElementById('emailDetailView');
            const emailBackBtn = document.getElementById('emailBackBtn');

            // Listeden e-postaya tıklanınca detay doldurma şovu
            emailItems.forEach(item => {
                item.addEventListener('click', function() {
                    emailItems.forEach(i => i.classList.remove('active'));
                    this.classList.add('active');
                    this.classList.remove('unread');

                    const senderName = this.getAttribute('data-sender-name');
                    const senderMail = this.getAttribute('data-sender-mail');
                    const subject = this.getAttribute('data-subject');
                    const date = this.getAttribute('data-date');
                    const fullBodyHTML = this.querySelector('.d-none-mail-body').innerHTML;

                    document.getElementById('viewSubject').textContent = subject;
                    document.getElementById('viewSenderName').textContent = senderName;
                    document.getElementById('viewSenderMail').textContent = `<${senderMail}>`;
                    document.getElementById('viewDate').textContent = date;
                    document.getElementById('viewAvatar').textContent = senderName.replace("Kime: ", "").charAt(0).toUpperCase();
                    document.getElementById('viewBody').innerHTML = fullBodyHTML;

                    emailListView.style.display = 'none';
                    emailDetailView.style.display = 'flex';
                });
            });

            // Geri Dönüş Butonu
            if(emailBackBtn) {
                emailBackBtn.addEventListener('click', function() {
                    emailDetailView.style.display = 'none';
                    emailListView.style.display = 'flex';
                });
            }

            // Canlı Arama Filtresi
            const searchInput = document.getElementById('emailSearchInput');
            if (searchInput) {
                searchInput.addEventListener('input', function (e) {
                    const searchVal = e.target.value.toLowerCase();
                    emailItems.forEach(item => {
                        const text = item.textContent.toLowerCase();
                        item.style.display = text.includes(searchVal) ? '' : 'none';
                    });
                });
            }
        });

        // Form Post İşlemi (AJAX)
        function submitComposeForm() {
            const form = document.getElementById('composeForm');
            const to = document.getElementById('composeTo').value.trim();
            const subject = document.getElementById('composeSubject').value.trim();
            const quillHtml = emailQuill.root.innerHTML;

            if (!to || !subject || quillHtml === '<p><br></p>' || quillHtml.trim() === '') {
                alert('Lütfen tüm alanları eksiksiz doldurun aga!');
                return;
            }

            document.getElementById('composeBody').value = quillHtml;

            const btnSend = document.getElementById('btnSendEmail');
            btnSend.disabled = true;
            btnSend.textContent = 'Gönderiliyor...';

            const formData = new FormData(form);

            fetch('/Admin/Email/Send', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    composeModalInstance.hide();
                    form.reset();
                    emailQuill.root.innerHTML = '';
                    window.location.reload();
                } else {
                    alert(data.message);
                }
            })
            .catch(() => alert('E-posta gönderilirken sistemsel bir hata oluştu!'))
            .finally(() => {
                btnSend.disabled = false;
                btnSend.innerHTML = '<i class="bi bi-send me-1"></i>Gönder';
            });
        }

        // Cevapla
        function replyCurrentEmail() {
            const currentSenderMail = document.getElementById('viewSenderMail').textContent.replace(/[<>]/g, '').trim();
            const currentSubject = document.getElementById('viewSubject').textContent;

            document.getElementById('composeTo').value = currentSenderMail;
            document.getElementById('composeSubject').value = currentSubject.startsWith("Re:") ? currentSubject : "Re: " + currentSubject;

            emailQuill.root.innerHTML = "<br><br>-------------------<br>Yanıtlanan Mesaj:<br>";
            composeModalInstance.show();
        }
    </script>
}