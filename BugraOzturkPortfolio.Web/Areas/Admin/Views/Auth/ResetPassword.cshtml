@{
    Layout = null;
    ViewData["Title"] = "Yeni Şifre Belirle";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - BugraOzturkPortfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
    <link href="~/Admin/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/Admin/assets/css/main.css" rel="stylesheet">
</head>
<body>
    <div class="fauth fauth-centered">
        <main class="fauth-main">
            <div class="fauth-main-inner">
                <a href="#" class="fauth-logo fauth-logo-center">
                    <img src="~/Admin/assets/img/logo.webp" alt="BugraPortfolio">
                    <span>BugraOzturk</span>
                </a>

                <div class="fauth-card fauth-card-sm">
                    <div class="fauth-card-head text-center">
                        <span class="fauth-icon"><i class="bi bi-shield-lock"></i></span>
                        <h1 class="fauth-title">Yeni Şifre Belirle</h1>
                        <p class="fauth-subtitle">Lütfen daha önce kullanmadığınız güçlü bir şifre seçiniz.</p>
                    </div>

                    <div id="alertMessage" class="alert d-none" role="alert"></div>

                    <form class="fauth-form" id="resetForm" novalidate>
                        <input type="hidden" name="email" value="@ViewBag.Email" />
                        <input type="hidden" name="token" value="@ViewBag.Token" />

                        <div class="fauth-field">
                            <label for="password" class="form-label">Yeni Şifre</label>
                            <div class="input-group">
                                <input type="password" class="form-control" id="password" name="password" placeholder="Yeni şifreniz" required>
                                <button class="btn btn-outline-secondary toggle-password" type="button"><i class="bi bi-eye"></i></button>
                            </div>
                        </div>

                        <div class="fauth-field">
                            <label for="confirmPassword" class="form-label">Yeni Şifre Tekrar</label>
                            <div class="input-group">
                                <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Şifre tekrarı" required>
                                <button class="btn btn-outline-secondary toggle-password" type="button"><i class="bi bi-eye"></i></button>
                            </div>
                        </div>

                        <button type="submit" id="btnSubmit" class="btn btn-primary w-100">Şifreyi Güncelle</button>
                    </form>

                    <p class="fauth-foot-text"><a href="/Admin/Auth/Login" class="fauth-link"><i class="bi bi-arrow-left"></i> Giriş ekranına dön</a></p>
                </div>
                <footer class="footer-centered">
                    <div class="footer-copyright">&copy; @DateTime.UtcNow.Year <a href="#">BugraOzturk</a>. Tüm Hakları Saklıdır.</div>
                </footer>
            </div>
        </main>
    </div>

    <script>
            // Şifre Görünürlüğü Değiştirme (Tüm butonlar için generic)
            document.querySelectorAll('.toggle-password').forEach(btn => {
                btn.addEventListener('click', function() {
                    const input = this.closest('.input-group').querySelector('input');
                    const icon = this.querySelector('i');
                    if (input.type === 'password') {
                        input.type = 'text';
                        icon.className = 'bi bi-eye-slash';
                    } else {
                        input.type = 'password';
                        icon.className = 'bi bi-eye';
                    }
                });
            });

            document.getElementById('resetForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                const alertDiv = document.getElementById('alertMessage');
                const btn = document.getElementById('btnSubmit');

                alertDiv.className = 'alert d-none';
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Güncelleniyor...';

                const formData = new FormData(this);

                try {
                    const response = await fetch('/Admin/Auth/ResetPassword', { method: 'POST', body: formData });
                    const res = await response.json();

                    if (res.success) {
                        alertDiv.className = 'alert alert-success';
                        alertDiv.textContent = res.message;
                        setTimeout(() => { window.location.href = '/Admin/Auth/Login'; }, 3000);
                    } else {
                        alertDiv.className = 'alert alert-danger';
                        alertDiv.textContent = res.message;
                        btn.disabled = false;
                        btn.innerHTML = 'Şifreyi Güncelle';
                    }
                    alertDiv.classList.remove('d-none');
                } catch {
                    alertDiv.className = 'alert alert-danger';
                    alertDiv.textContent = 'Sistem hatası oluştu!';
                    alertDiv.classList.remove('d-none');
                    btn.disabled = false;
                    btn.innerHTML = 'Şifreyi Güncelle';
                }
            });
    </script>
</body>
</html>