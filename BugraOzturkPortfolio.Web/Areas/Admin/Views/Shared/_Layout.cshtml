@{
    var firstName = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.GivenName)?.Value ?? "";
    var lastName = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Surname)?.Value ?? "";
    var username = User.Identity?.Name ?? "";
    var fullNameWithUser = $"{firstName} {lastName} ({username})";
    var currentPath = Context.Request.Path.Value ?? "";
}

<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - FlexAdmin</title>
    <meta name="description" content="FlexAdmin - Bootstrap Admin Template">
    <meta name="keywords" content="admin, dashboard, bootstrap">

    <link href="~/Admin/assets/img/favicon.png" rel="icon">
    <link href="~/Admin/assets/img/apple-touch-icon.png" rel="apple-touch-icon">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">

    <link href="~/Admin/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/remixicon/remixicon.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/phosphor-icons/phosphor-icons.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/lucide-icons/lucide.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/simple-datatables/style.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/quill/quill.snow.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/quill/quill.bubble.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/choices.js/choices.min.css" rel="stylesheet">
    <link href="~/Admin/assets/vendor/flatpickr/flatpickr.min.css" rel="stylesheet">

    <link href="~/Admin/assets/css/main.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />
</head>

<body>
    <header class="header">
        <div class="header-left">
            <a href="/Admin/Dashboard" class="header-logo">
                <span>Buğra Portfolio Admin</span>
            </a>
        </div>

        <button class="sidebar-toggle" title="Menüyü Aç/Kapat">
            <i class="bi bi-layout-sidebar-inset"></i>
        </button>

        <div class="header-search">
            <div class="search-form">
                <i class="bi bi-search search-icon"></i>
                <input type="text" id="sidebarSearchInput" placeholder="Menüde ara... ( / )" autocomplete="off">
                <kbd class="search-shortcut">/</kbd>
            </div>
        </div>

        <div class="header-right">
            <div class="header-actions-desktop">
                <div class="header-action-cluster">
                    <button class="header-action theme-toggle" title="Temayı Değiştir">
                        <i class="ph-light ph-moon-stars theme-icon-dark"></i>
                        <i class="ph-light ph-sun theme-icon-light"></i>
                    </button>

                  
                        @await Component.InvokeAsync("AdminMessagesDropdown")
                </div>

                <span class="header-divider"></span>

                <div class="header-action-wrap dropdown user-dropdown">
                    <button class="dropdown-toggle user-trigger" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="~/Admin/assets/img/profile-img.webp" alt="Kullanıcı" class="user-avatar">
                        <div class="user-brief">
                            <span class="user-name">@fullNameWithUser</span>
                            <span class="user-role">Full Stack Developer</span>
                        </div>
                        <i class="bi bi-chevron-down user-chevron"></i>
                    </button>

                    <div class="dropdown-menu dropdown-menu-end user-menu">
                        <div class="user-menu-header">
                            <img src="~/Admin/assets/img/profile-img.webp" alt="Kullanıcı" class="user-menu-avatar">
                            <div class="user-menu-info">
                                <div class="user-menu-name">@firstName @lastName</div>
                                <div class="user-menu-email">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value</div>
                            </div>
                        </div>
                        <div class="user-menu-body">
                            <a class="user-menu-item" href="/Admin/Profile">
                                <span class="user-menu-icon"><i class="bi bi-person"></i></span>
                                <span>Profilim</span>
                            </a>
                        </div>
                        <div class="user-menu-footer">
                            <a class="user-menu-logout" href="/Admin/Auth/Logout">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Çıkış Yap</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="header-actions-mobile">
                <button class="header-action search-toggle" title="Ara">
                    <i class="bi bi-search"></i>
                </button>
                <button class="header-action mobile-menu-toggle" title="Daha Fazla">
                    <i class="bi bi-three-dots"></i>
                </button>
            </div>
        </div>
    </header>

    <div class="mobile-search">
        <div class="search-form">
            <input type="text" id="mobileSidebarSearchInput" placeholder="Menüde ara..." autocomplete="off">
        </div>
    </div>

    <div class="mobile-header-menu">
        <div class="mobile-header-menu-content">
            <button class="mobile-menu-item theme-toggle" title="Tema Değiştir">
                <i class="ph-light ph-moon-stars theme-icon-dark"></i>
                <i class="ph-light ph-sun theme-icon-light"></i>
                <span class="mobile-menu-label">Tema</span>
            </button>

            <a href="#" class="mobile-menu-item">
                <i class="bi bi-chat-left-text"></i>
                <span class="mobile-menu-label">Mesajlar</span>
            </a>

            <a href="/Admin/Profile" class="mobile-menu-item">
                <i class="bi bi-person"></i>
                <span class="mobile-menu-label">Profilim</span>
            </a>

            <a href="/Admin/Auth/Logout" class="mobile-menu-item mobile-menu-item-danger">
                <i class="bi bi-box-arrow-right"></i>
                <span class="mobile-menu-label">Çıkış Yap</span>
            </a>
        </div>
    </div>

    <aside class="sidebar">
        <nav class="sidebar-nav">
            <ul class="nav-menu" id="sidebarMenu">

                <li class="nav-item">
                    <a class="nav-link @(currentPath.Equals("/Admin/Dashboard", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/Dashboard">
                        <span class="nav-icon"><i class="ph-light ph-squares-four"></i></span>
                        <span class="nav-text">Panel Ana Sayfa</span>
                        <span class="nav-badge nav-badge-soft">Ana</span>
                    </a>
                </li>

                <li class="nav-heading"><span>Portfolyo İçerikleri</span></li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/About", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/About">
                        <span class="nav-icon"><i class="ph-light ph-user-focus"></i></span>
                        <span class="nav-text">Hakkımda</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/Project", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/Project">
                        <span class="nav-icon"><i class="ph-light ph-folder-open"></i></span>
                        <span class="nav-text">Projelerim</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/Category", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/Category">
                        <span class="nav-icon"><i class="ph-light ph-circles-three"></i></span>
                        <span class="nav-text">Kategoriler</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/Education", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/Education">
                        <span class="nav-icon"><i class="ph-light ph-graduation-cap"></i></span>
                        <span class="nav-text">Eğitim Hayatım</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/Experience", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/Experience">
                        <span class="nav-icon"><i class="ph-light ph-briefcase"></i></span>
                        <span class="nav-text">İş Deneyimlerim</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/Service", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/Service">
                        <span class="nav-icon"><i class="ph-light ph-handshake"></i></span>
                        <span class="nav-text">Hizmetlerim</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/Skill", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/Skill">
                        <span class="nav-icon"><i class="ph-light ph-cpu"></i></span>
                        <span class="nav-text">Yeteneklerim</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/Testimonial", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/Testimonial">
                        <span class="nav-icon"><i class="ph-light ph-chat-centered-text"></i></span>
                        <span class="nav-text">Referanslar</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center @(currentPath.StartsWith("/Admin/ContactMessage", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/ContactMessage">
                        <span class="nav-icon"><i class="ph-light ph-envelope-simple"></i></span>
                        <span class="nav-text">Gelen Mesajlar</span>
                        @await Component.InvokeAsync("AdminSidebarMessagesBadge")
                    </a>
                </li>

                <li class="nav-heading"><span>Sistem & Yapılandırma</span></li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/Calendar", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/Calendar">
                        <span class="nav-icon"><i class="ph-light ph-calendar-blank"></i></span>
                        <span class="nav-text">Ziyaretçi Takvimi</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/SiteSetting", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/SiteSetting">
                        <span class="nav-icon"><i class="ph-light ph-sliders"></i></span>
                        <span class="nav-text">Site Ayarları</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/SiteScript", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/SiteScript">
                        <span class="nav-icon"><i class="ph-light ph-code"></i></span>
                        <span class="nav-text">Script Yönetimi</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentPath.StartsWith("/Admin/User", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Admin/User">
                        <span class="nav-icon"><i class="ph-light ph-users-three"></i></span>
                        <span class="nav-text">Sistem Kullanıcıları</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Anasayfa" target="_blank">
                        <span class="nav-icon"><i class="ph-light ph-google-chrome-logo"></i></span>
                        <span class="nav-text">Siteye Geri Dön</span>
                    </a>
                </li>

            </ul>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-footer-user">
                <a href="/Admin/Profile" class="sidebar-footer-profile">
                    <img src="~/Admin/assets/img/profile-img.webp" alt="Kullanıcı" class="sidebar-footer-avatar">
                    <div class="sidebar-footer-info">
                        <div class="sidebar-footer-name">@fullNameWithUser</div>
                        <div class="sidebar-footer-role">Geliştirici</div>
                    </div>
                </a>
            </div>
        </div>
    </aside>

    <div class="sidebar-overlay"></div>

    <main class="main">
        <div class="main-content page-dashboard">
            @RenderBody()
        </div>

        <footer class="footer">
            <div class="footer-content">
                <div class="footer-credits">
                    <div class="footer-copyright">
                        &copy; @DateTime.UtcNow.Year <a href="#">Buğra Öztürk</a>
                    </div>
                </div>
            </div>
        </footer>
    </main>

    <a href="#" class="back-to-top">
        <i class="bi bi-arrow-up"></i>
    </a>

    <script src="~/Admin/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/Admin/assets/vendor/apexcharts/apexcharts.min.js"></script>
    <script src="~/Admin/assets/vendor/chart.js/chart.umd.js"></script>
    <script src="~/Admin/assets/vendor/echarts/echarts.min.js"></script>
    <script src="~/Admin/assets/vendor/simple-datatables/simple-datatables.js"></script>
    <script src="~/Admin/assets/vendor/quill/quill.js"></script>
    <script src="~/Admin/assets/vendor/tinymce/tinymce.min.js"></script>
    <script src="~/Admin/assets/vendor/choices.js/choices.min.js"></script>
    <script src="~/Admin/assets/vendor/flatpickr/flatpickr.min.js"></script>

    <script src="~/Admin/assets/js/theme.js"></script>
    <script src="~/Admin/assets/js/main.js"></script>
    <script src="~/Admin/assets/js/apps-sidebar-toggle.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        const desktopInput = document.getElementById("sidebarSearchInput");
        const mobileInput = document.getElementById("mobileSidebarSearchInput");
        const menuItems = document.querySelectorAll("#sidebarMenu .nav-item");
        const menuHeadings = document.querySelectorAll("#sidebarMenu .nav-heading");

        function localeStringNormalize(str) {
        return str
        .trim()
        .toLowerCase()
        .replace(/ğ/g, "g")
        .replace(/ü/g, "u")
        .replace(/ş/g, "s")
        .replace(/ı/g, "i")
        .replace(/i̇/g, "i")
        .replace(/ö/g, "o")
        .replace(/ç/g, "c");
        }

        function filterSidebarMenu(searchText) {
        const normalizedSearch = localeStringNormalize(searchText);

        menuItems.forEach(item => {
        const textElement = item.querySelector(".nav-text");
        if (!textElement) return;

        const normalizedText = localeStringNormalize(textElement.textContent);

        if (normalizedText.includes(normalizedSearch)) {
        item.style.setProperty("display", "", "important");
        } else {
        item.style.setProperty("display", "none", "important");
        }
        });

        menuHeadings.forEach(heading => {
        let nextEl = heading.nextElementSibling;
        let hasVisibleItem = false;

        while (nextEl && !nextEl.classList.contains("nav-heading")) {
        if (nextEl.classList.contains("nav-item") && nextEl.style.display !== "none") {
        hasVisibleItem = true;
        break;
        }
        nextEl = nextEl.nextElementSibling;
        }

        if (hasVisibleItem || normalizedSearch === "") {
        heading.style.setProperty("display", "", "important");
        } else {
        heading.style.setProperty("display", "none", "important");
        }
        });
        }

        if (desktopInput) {
        desktopInput.addEventListener("input", function (e) {
        filterSidebarMenu(e.target.value);
        });

        document.addEventListener("keydown", function (e) {
        if (e.key === "/" && document.activeElement !== desktopInput && document.activeElement !== mobileInput) {
        e.preventDefault();
        desktopInput.focus();
        }
        });
        }

        if (mobileInput) {
        mobileInput.addEventListener("input", function (e) {
        filterSidebarMenu(e.target.value);
        });
        }
        });
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/messageHub")
        .withAutomaticReconnect() 
        .build();

        connection.on("ReceiveNewMessage", function (message) {

        const sidebarLink = document.querySelector("a[href='/Admin/ContactMessage']");
        if (sidebarLink) {
        let sidebarBadge = sidebarLink.querySelector(".badge");
        if (!sidebarBadge) {
        sidebarBadge = document.createElement("span");
        sidebarBadge.className = "badge bg-danger ms-auto rounded-pill";
        sidebarBadge.style.cssText = "font-size: 0.75rem; padding: 0.35em 0.65em;";
        sidebarLink.appendChild(sidebarBadge);
        }
        let currentCount = parseInt(sidebarBadge.textContent) || 0;
        sidebarBadge.textContent = currentCount + 1;
        }

        const dropdownToggle = document.querySelector(".messages-dropdown .header-action");
        if (dropdownToggle) {
        let headerBadge = dropdownToggle.querySelector(".header-badge");
        if (!headerBadge) {
        headerBadge = document.createElement("span");
        headerBadge.className = "header-badge";
        dropdownToggle.appendChild(headerBadge);
        }
        let currentHeaderCount = parseInt(headerBadge.textContent) || 0;
        headerBadge.textContent = currentHeaderCount + 1;

        const notificationCountText = document.querySelector(".messages-menu .notification-count");
        if (notificationCountText) {
        notificationCountText.textContent = (currentHeaderCount + 1) + " yeni mesaj var";
        }
        }

        const notificationList = document.querySelector(".messages-menu .notification-list");
        if (notificationList) {
        const emptyText = notificationList.querySelector(".text-center");
        if (emptyText) emptyText.remove();

        const newItem = document.createElement("a");
        newItem.href = `/Admin/ContactMessage/Detail/${message.id}`;
        newItem.className = "notification-item unread animate__animated animate__fadeInDown"; 
        newItem.innerHTML = `
        <span class="notification-dot"></span>
        <div class="notification-content">
        <div class="notification-title">${message.fullName}</div>
        <div class="notification-text">${message.subject}</div>
        <span class="notification-time">${message.createdDate}</span>
        </div>
        `;

        notificationList.insertBefore(newItem, notificationList.firstChild);

        if (notificationList.children.length > 5) {
        notificationList.lastChild.remove();
        }
        }

        if (typeof showProjectToast === "function") {
        showProjectToast(`Yeni Mesaj: ${message.fullName} bir mesaj gönderdi!`, true);
        }
        });

        // Bağlantıyı başlat
        connection.start().catch(function (err) {
        return console.error(err.toString());
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>