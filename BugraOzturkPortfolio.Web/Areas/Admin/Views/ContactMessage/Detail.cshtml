@model ContactMessage
@{
    ViewData["Title"] = "Mesaj Detayı";

    (string DeviceName, string IconClass) GetDeviceDetails(string userAgent)
    {
        if (string.IsNullOrEmpty(userAgent)) return ("Bilinmeyen Cihaz", "bi-laptop-fill");

        string ua = userAgent.ToLower();
        if (ua.Contains("iphone")) return ("iPhone", "bi-phone-fill ");
        if (ua.Contains("ipad")) return ("iPad", "bi-tablet-fill ");
        if (ua.Contains("android")) return ("Android", "bi-phone text-success");
        if (ua.Contains("windows")) return ("Windows PC", "bi-windows text-primary");
        if (ua.Contains("macintosh") || ua.Contains("mac os")) return ("Mac", "bi-apple ");
        if (ua.Contains("linux")) return ("Linux PC", "bi-terminal text-warning");

        return ("Web Cihazı", "bi-globe text-secondary");
    }

    var device = GetDeviceDetails(Model.UserAgent);
}

<div class="pagetitle">
    <h1>Mesaj Detayı</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Admin/ContactMessage">Mesajlar</a></li>
            <li class="breadcrumb-item active">Detay</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center pt-3">
                    <h5 class="card-title m-0 p-0">@Model.Subject</h5>
                    <a href="/Admin/ContactMessage" class="btn btn-sm btn-secondary">
                        <i class="bi bi-arrow-left"></i> Listeye Dön
                    </a>
                </div>
                <div class="card-body pt-3">
                    <div class="row mb-3 gy-3">
                        <div class="col-md-3">
                            <label class=" d-block small fw-semibold">Gönderen Kişi</label>
                            <strong>@Model.FullName</strong>
                        </div>
                        <div class="col-md-3">
                            <label class=" d-block small fw-semibold">E-Posta Adresi</label>
                            <a href="mailto:@Model.Email">@Model.Email</a>
                        </div>
                        <div class="col-md-3">
                            <label class=" d-block small fw-semibold">Telefon Numarası</label>
                            <a href="tel:@Model.PhoneNumber" class="font-monospace fw-bold  text-decoration-none">
                                <i class="bi bi-telephone-outbound me-1 small text-success"></i>@Model.PhoneNumber
                            </a>
                        </div>
                        <div class="col-md-3">
                            <label class=" d-block small fw-semibold">Tarih / IP</label>
                            <span>@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</span> / <span class="badge bg-secondary">@Model.IpAddress</span>
                        </div>
                    </div>

                    <hr>

                    <div class="mb-3">
                        <label class=" d-block small fw-semibold mb-2">Mesaj İçeriği</label>
                        <div class="p-3 bg-light rounded" style="white-space: pre-wrap; min-height: 150px; line-height: 1.6;">@Model.Body</div>
                    </div>

                    <div class="mt-4 p-2 border rounded d-flex align-items-center justify-content-between">
                        <div class="small text-secondary">
                            <i class="bi @device.IconClass me-1"></i> Gönderen Cihaz: <strong>@device.DeviceName</strong>
                        </div>
                        <div class="small  font-monospace text-truncate ms-3" style="max-width: 60%;" title="@Model.UserAgent">
                            UA: @Model.UserAgent
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>