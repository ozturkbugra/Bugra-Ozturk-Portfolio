@model ContactMessage
@{
    ViewData["Title"] = "Mesaj Detayı";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Mesaj Detayı</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Admin/ContactMessage">Mesajlar</a></li>
            <li class="breadcrumb-item active">Detay</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center bg-white pt-3">
                    <h5 class="card-title m-0 p-0">@Model.Subject</h5>
                    <a href="/Admin/ContactMessage" class="btn btn-sm btn-secondary">
                        <i class="bi bi-arrow-left"></i> Listeye Dön
                    </a>
                </div>
                <div class="card-body pt-3">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="text-muted d-block">Gönderen Kişi</label>
                            <strong>@Model.FullName</strong>
                        </div>
                        <div class="col-md-4">
                            <label class="text-muted d-block">E-Posta Adresi</label>
                            <a href="mailto:@Model.Email">@Model.Email</a>
                        </div>
                        <div class="col-md-4">
                            <label class="text-muted d-block">Tarih / IP</label>
                            <span>@Model.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span> / <span class="badge bg-secondary">@Model.IpAddress</span>
                        </div>
                    </div>

                    <hr>

                    <div class="mb-3">
                        <label class="text-muted d-block mb-2">Mesaj İçeriği</label>
                        <div class="p-3 bg-light rounded" style="white-space: pre-wrap; min-height: 150px; line-height: 1.6;">@Model.Body</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>