@model List<ContactMessage>
@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="pagetitle">
    <h1>Gelen Mesajlar</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active">Mesajlar</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-body pt-3">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 50px;">Durum</th>
                                    <th>Gönderen</th>
                                    <th>Konu</th>
                                    <th>Tarih</th>
                                    <th>IP Adresi</th>
                                    <th style="width: 150px;" class="text-end">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var msg in Model)
                                    {
                                        string rowStyle = !msg.IsRead ? "fw-bold table-light" : string.Empty;

                                        <tr class="@rowStyle" id="row-@msg.Id">
                                            <td>
                                                @if (!msg.IsRead)
                                                {
                                                    <i class="bi bi-envelope-fill text-primary fs-5" title="Okunmadı"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-envelope-open text-muted fs-5" title="Okundu"></i>
                                                }
                                            </td>
                                            <td>@msg.FullName<br><small class="text-muted">@msg.Email</small></td>
                                            <td>@msg.Subject</td>
                                            <td>@msg.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                            <td><span class="badge bg-secondary">@msg.IpAddress</span></td>
                                            <td class="text-end">
                                                <a href="/Admin/ContactMessage/Detail/@msg.Id" class="btn btn-sm btn-outline-info" title="Oku">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <button type="button" class="btn btn-sm btn-outline-danger ms-1" onclick="deleteMessage('@msg.Id')" title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">Gelen mesaj bulunamadı aga.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    async function deleteMessage(id) {
        if (!confirm('Bu mesajı silmek istediğine emin misin aga?')) return;

        try {
            const response = await fetch(`/Admin/ContactMessage/Delete/${id}`, {
                method: 'POST'
            });
            const res = await response.json();

            if (res.success) {
                const row = document.getElementById(`row-${id}`);
                if (row) {
                    row.style.transition = 'all 0.5s ease';
                    row.style.opacity = '0';
                    setTimeout(() => row.remove(), 500);
                }
            } else {
                alert(res.message);
            }
        } catch (error) {
            alert('Mesaj silinirken bir bağlantı hatası oluştu!');
        }
    }
</script>