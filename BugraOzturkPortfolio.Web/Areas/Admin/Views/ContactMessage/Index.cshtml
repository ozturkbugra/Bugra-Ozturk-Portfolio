@model List<ContactMessage>
@{
    ViewData["Title"] = "Gelen Mesajlar";

    (string DeviceName, string IconClass) GetDeviceDetails(string userAgent)
    {
        if (string.IsNullOrEmpty(userAgent)) return ("Bilinmeyen Cihaz", "bi-laptop-fill");
        string ua = userAgent.ToLower();
        if (ua.Contains("iphone")) return ("iPhone", "bi-phone-fill ");
        if (ua.Contains("ipad")) return ("iPad", "bi-tablet-fill ");
        if (ua.Contains("android")) return ("Android", "bi-phone text-success");
        if (ua.Contains("windows")) return ("Windows PC", "bi-windows text-primary");
        if (ua.Contains("macintosh") || ua.Contains("mac os")) return ("Mac", "bi-apple ");
        if (ua.Contains("linux")) return ("Linux PC", "bi-terminal text-warning");
        return ("Web Cihazı", "bi-globe text-secondary");
    }
}

<div class="pagetitle">
    <h1>Gelen Mesajlar</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active">Mesajlar</li>
        </ol>
    </nav>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-12">
            <div class="card mb-3 d-none" id="bulkActionsBar">
                <div class="card-body d-flex align-items-center justify-content-between py-2">
                    <div>
                        <span class="fw-bold text-secondary" id="selectedCountText">0 satır seçildi</span>
                    </div>
                    <div>
                        <button type="button" class="btn btn-danger btn-sm" onclick="deleteSelectedMessages()">
                            <i class="bi bi-trash-fill me-1"></i> Seçilenleri Sil
                        </button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body pt-3">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle" id="msgDataTable">
                            <thead>
                                <tr>
                                    <th style="width: 40px;" data-sortable="false">
                                        <input type="checkbox" class="form-check-input" id="checkAllMessages">
                                    </th>
                                    <th style="width: 50px;">Durum</th>
                                    <th>Gönderen</th>
                                    <th>Telefon</th>
                                    <th>Konu</th>
                                    <th>Tarih</th>
                                    <th>Cihaz / IP</th>
                                    <th style="width: 150px;" class="text-end" data-sortable="false">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var msg in Model)
                                    {
                                        string rowStyle = !msg.IsRead ? "fw-bold table-light" : string.Empty;
                                        var device = GetDeviceDetails(msg.UserAgent);

                                        <tr class="@rowStyle" id="row-@msg.Id">
                                            <td>
                                                <input type="checkbox" class="form-check-input msg-checkbox" data-id="@msg.Id">
                                            </td>
                                            <td>
                                                @if (!msg.IsRead)
                                                {
                                                    <i class="bi bi-envelope-fill text-primary fs-5" title="Okunmadı"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-envelope-open fs-5" title="Okundu"></i>
                                                }
                                            </td>
                                            <td>@msg.FullName<br><small class="">@msg.Email</small></td>
                                            <td><span class="font-monospace">@msg.PhoneNumber</span></td>
                                            <td>@msg.Subject</td>
                                            <td>@msg.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td>
                                                <div class="d-flex flex-column gap-1">
                                                    <small class=" d-flex align-items-center gap-1">
                                                        <i class="bi @device.IconClass"></i> @device.DeviceName
                                                    </small>
                                                    <span class="badge bg-secondary w-fit">@msg.IpAddress</span>
                                                </div>
                                            </td>
                                            <td class="text-end">
                                                <a href="/Admin/ContactMessage/Detail/@msg.Id" class="btn btn-sm btn-outline-info" title="Oku">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <button type="button" class="btn btn-sm btn-outline-danger ms-1" onclick="deleteMessage('@msg.Id')" title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" class="text-center py-4">Gelen mesaj bulunamadı</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    let lastChecked = null;

    document.addEventListener("DOMContentLoaded", function() {
        const table = document.getElementById("msgDataTable");
        if (table && typeof simpleDatatables !== "undefined") {
            new simpleDatatables.DataTable(table, {
                searchable: true,
                fixedHeight: false,
                perPage: 10,
                labels: {
                    placeholder: "Mesajlarda ara...",
                    perPage: "satır göster",
                    noRows: "Eşleşen mesaj bulunamadı.",
                    info: "{rows} mesajdan {start} ile {end} arası gösteriliyor"
                }
            });
        }

        document.body.addEventListener('change', function(e) {
            if (e.target && e.target.id === 'checkAllMessages') {
                toggleAll(e.target.checked);
            }
            if (e.target && e.target.classList.contains('msg-checkbox')) {
                updateBulkActionsBar();
            }
        });

        document.body.addEventListener('click', function(e) {
            if (e.target && e.target.classList.contains('msg-checkbox')) {
                const checkboxes = Array.from(document.querySelectorAll('.msg-checkbox'));

                if (e.shiftKey && lastChecked) {
                    let start = checkboxes.indexOf(e.target);
                    let end = checkboxes.indexOf(lastChecked);

                    checkboxes.slice(Math.min(start, end), Math.max(start, end) + 1)
                              .forEach(cb => cb.checked = lastChecked.checked);
                }
                lastChecked = e.target;
                updateBulkActionsBar();
            }
        });
    });

    function toggleAll(isChecked) {
        document.querySelectorAll('.msg-checkbox').forEach(cb => {
            cb.checked = isChecked;
        });
        updateBulkActionsBar();
    }

    function updateBulkActionsBar() {
        const checkedBoxes = document.querySelectorAll('.msg-checkbox:checked');
        const bar = document.getElementById('bulkActionsBar');
        const text = document.getElementById('selectedCountText');

        if (checkedBoxes.length > 0) {
            bar.classList.remove('d-none');
            text.textContent = `${checkedBoxes.length} satır seçildi`;
        } else {
            bar.classList.add('d-none');
            const checkAll = document.getElementById('checkAllMessages');
            if(checkAll) checkAll.checked = false;
        }
    }

    async function deleteMessage(id) {
        if (!confirm('Bu mesajı silmek istediğine emin misin?')) return;
        executeDelete([id]);
    }

    async function deleteSelectedMessages() {
        const checkedBoxes = document.querySelectorAll('.msg-checkbox:checked');
        const ids = Array.from(checkedBoxes).map(cb => cb.getAttribute('data-id'));

        if (ids.length === 0) return;
        if (!confirm(`Seçtiğin ${ids.length} adet mesajı toplu silmek istediğine emin misin?`)) return;

        executeDelete(ids, true);
    }
    async function executeDelete(ids, isBulk = false) {
        try {
            const url = isBulk ? '/Admin/ContactMessage/DeleteMultiple' : `/Admin/ContactMessage/Delete/${ids[0]}`;
            const options = isBulk ? {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(ids)
            } : { method: 'POST' };

            const response = await fetch(url, options);
            const res = await response.json();

            if (res.success) {
                ids.forEach(id => {
                    const row = document.getElementById(`row-${id}`);
                    if (row) {
                        row.style.transition = 'all 0.5s ease';
                        row.style.opacity = '0';
                        setTimeout(() => {
                            row.remove();
                            updateBulkActionsBar();
                        }, 500);
                    }
                });
                if(isBulk) {
                     setTimeout(() => location.reload(), 600); 
                }
            } else {
                alert(res.message);
            }
        } catch (error) {
            alert('İşlem gerçekleştirilirken bir bağlantı hatası oluştu!');
        }
    }
</script>