<script>
    document.addEventListener("DOMContentLoaded", function () {
    const cookieBar = document.getElementById("cookieNoticeBar");
    const acceptBtn = document.getElementById("btnAcceptCookies");

    if (cookieBar && acceptBtn) {
    const lastAccepted = localStorage.getItem("cookie_accepted_date");
    const oneWeek = 7 * 24 * 60 * 60 * 1000;

    if (!lastAccepted || (new Date().getTime() - parseInt(lastAccepted)) > oneWeek) {
    cookieBar.style.display = "block";
    }

    acceptBtn.addEventListener("click", function () {
    localStorage.setItem("cookie_accepted_date", new Date().getTime().toString());

    cookieBar.style.transition = "opacity 0.4s ease";
    cookieBar.style.opacity = "0";
    setTimeout(() => {
    cookieBar.style.display = "none";
    }, 400);
    });
    }
    });

    document.addEventListener("DOMContentLoaded", function () {
    document.addEventListener('click', function (e) {
    const toggleBtn = e.target.closest('.header-toggle');
    if (toggleBtn) {
    const headerEl = document.getElementById('header');
    if (headerEl) {
    headerEl.classList.toggle('header-show');
    }
    const iconEl = toggleBtn.classList.contains('bi') ? toggleBtn : toggleBtn.querySelector('.bi');
    if (iconEl) {
    iconEl.classList.toggle('bi-list');
    iconEl.classList.toggle('bi-x');
    }
    }
    });
    });


</script>