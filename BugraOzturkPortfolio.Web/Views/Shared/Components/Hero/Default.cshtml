@model About

<section id="hero" class="hero section">
    <div class="background-elements">
        <div class="bg-circle circle-1"></div>
        <div class="bg-circle circle-2"></div>
    </div>

    <div class="hero-content">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6" data-aos="fade-right" data-aos-delay="100">
                    <div class="hero-text">
                        @if (Model != null)
                        {
                            <h1>Buğra <span class="accent-text">ÖZTÜRK</span></h1>
                            <p class="lead"><span class="typed" data-typed-items="@Model.Title"></span></p>
                            @if (!string.IsNullOrEmpty(Model.SubTitle))
                            {
                                <h3 class="h5 text-muted my-3">@Model.SubTitle</h3>
                            }
                        }
                        else
                        {
                            <h1>Buğra <span class="accent-text">ÖZTÜRK</span></h1>
                            <p class="lead"><span class="typed" data-typed-items="Full Stack .NET Developer, Software Architect"></span></p>
                        }

                        <div class="hero-actions">
                            <a href="/portfolyo" class="btn btn-primary">Çalışmalarımı Gör</a>
                            <a href="/iletisim" class="btn btn-outline">İletişime Geç</a>
                        </div>

                        <div class="social-links">
                            @if (Model != null)
                            {
                                if (!string.IsNullOrEmpty(Model.TwitterUrl))
                                {
                                    <a href="@Model.TwitterUrl" target="_blank"><i class="bi bi-twitter-x"></i></a>
                                }
                                if (!string.IsNullOrEmpty(Model.FacebookUrl))
                                {
                                    <a href="@Model.FacebookUrl" target="_blank"><i class="bi bi-facebook"></i></a>
                                }
                                if (!string.IsNullOrEmpty(Model.InstagramUrl))
                                {
                                    <a href="@Model.InstagramUrl" target="_blank"><i class="bi bi-instagram"></i></a>
                                }
                                if (!string.IsNullOrEmpty(Model.LinkedinUrl))
                                {
                                    <a href="@Model.LinkedinUrl" target="_blank"><i class="bi bi-linkedin"></i></a>
                                }
                            }
                        </div>
                    </div>
                </div>

                <div class="col-lg-6" data-aos="fade-left" data-aos-delay="200">
                    <div class="hero-visual">
                        <div class="profile-container">
                            <div class="profile-background"></div>
                            <img src="@(Model != null && !string.IsNullOrEmpty(Model.ImageUrl) ? Model.ImageUrl : "/Admin/assets/img/profile-img.webp")" alt="Buğra Öztürk" class="profile-image" style="object-fit: cover;">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>