<!DOCTYPE html>
<html lang="tr">
<head>
    @await Component.InvokeAsync("Head")

    <link href="https://fonts.googleapis.com" rel="preconnect">
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&family=Nunito:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

    <link href="~/UI/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/UI/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/UI/assets/vendor/aos/aos.css" rel="stylesheet">
    <link href="~/UI/assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
    <link href="~/UI/assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">

    <link href="~/UI/assets/css/main.css" rel="stylesheet">

    @await RenderSectionAsync("Styles", required: false)

    @await Component.InvokeAsync("SiteScript", new { position = BugraOzturkPortfolio.Entities.Concrete.ScriptPosition.Header })
</head>
<body class="index-page">
    @await Component.InvokeAsync("SiteScript", new { position = BugraOzturkPortfolio.Entities.Concrete.ScriptPosition.BodyStart })

    @await Component.InvokeAsync("Header")

    <main class="main">
        @RenderBody()
    </main>

    <footer id="footer" class="footer position-relative">
        <div class="container">
            <div class="copyright text-center">
                <p>© @DateTime.UtcNow.Year <strong class="px-1 sitename">Buğra Öztürk</strong> <span>Tüm Hakları Saklıdır.</span></p>
            </div>
        </div>
    </footer>

    <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    <div id="preloader"></div>

  

    @await RenderSectionAsync("Scripts", required: false)

    @await Component.InvokeAsync("SiteScript", new { position = BugraOzturkPortfolio.Entities.Concrete.ScriptPosition.BodyEnd })

    <div id="cookieNoticeBar" class="bg-dark text-white py-3 position-fixed bottom-0 start-0 w-100" style="z-index: 9999; display: none; box-shadow: 0 -5px 15px rgba(0,0,0,0.15);">
        <div class="container d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
            <div class="text-center text-md-start small">
                <i class="bi bi-shield-check text-success me-2 fs-5 align-middle"></i>
                Sitemizde, ziyaretçi trafiğini anonim olarak analiz etmek ve kullanıcı deneyimini artırmak adına çerezler kullanılmaktadır. Sitemizi kullanmaya devam ederek gizlilik politikamızı kabul etmiş sayılırsınız.
            </div>
            <div class="text-nowrap">
                <button type="button" id="btnAcceptCookies" class="btn btn-light btn-sm fw-bold px-4">Anladım</button>
            </div>
        </div>
    </div>

    @await Component.InvokeAsync("LayoutScript")


</body>
</html>